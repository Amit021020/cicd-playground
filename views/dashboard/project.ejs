<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Projects</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-950 text-white min-h-screen">

    <!-- Header -->
    <div class="border-b border-zinc-800 p-6">
        <h1 class="text-2xl font-bold">Your Projects</h1>
        <p class="text-zinc-400 text-sm">All projects and deployments overview</p>
    </div>

    <!-- Projects List -->
    <div class="p-6 space-y-8">

        <% projects.forEach(project => { %>

            <!-- Single Project Card -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6">

                <!-- Project Info -->
                <div class="mb-4">
                    <h2 class="text-xl font-bold"><%= project.projectname %></h2>
                    <p class="text-zinc-400 text-sm">
                        Repo: <%= project.repoUrl %>
                    </p>
                    <p class="text-zinc-400 text-sm">
                        Branch: <%= project.branch %>
                    </p>
                </div>

                <!-- Filter deployments for THIS project -->
                <% 
                    let projectDeployments = deployments.filter(dep => 
                        dep.projectId.toString() === project._id.toString()
                    );
                %>

                <!-- Stats -->
                <div class="flex gap-6 text-sm text-zinc-300 mb-4">
                    <p>Total Deployments: <%= projectDeployments.length %></p>
                    <p>
                        Latest Status:
                        <%= projectDeployments[0] ? projectDeployments[0].status : "N/A" %>
                    </p>
                </div>

                <!-- Deployments Table -->
                <div class="overflow-x-auto">

                    <table class="w-full text-sm">

                        <thead class="text-zinc-400 border-b border-zinc-800">
                            <tr>
                                <th class="text-left p-2">ID</th>
                                <th>Status</th>
                                <th>Container</th>
                                <th>Created</th>
                                <th>Logs</th>
                            </tr>
                        </thead>

                        <tbody>

                            <% projectDeployments.forEach(dep => { %>
                                <tr class="border-b border-zinc-800">

                                    <td class="p-2 text-zinc-300">
                                        <%= dep._id %>
                                    </td>

                                    <td>
                                        <span class="
                                            px-2 py-1 rounded text-xs
                                            <%= dep.status === 'success' ? 'bg-green-600' : '' %>
                                            <%= dep.status === 'failed' ? 'bg-red-600' : '' %>
                                            <%= dep.status === 'building' ? 'bg-yellow-600' : '' %>
                                            <%= dep.status === 'queued' ? 'bg-zinc-600' : '' %>
                                        ">
                                            <%= dep.status %>
                                        </span>
                                    </td>

                                    <td class="text-zinc-400">
                                        <%= dep.containerId || "N/A" %>
                                    </td>

                                    <td class="text-zinc-400">
                                        <%= new Date(dep.createdAt).toISOString().slice(0,10) %>
                                    </td>

                                    <td>
                                        <a href="/deployments/logs/<%= dep._id %>"
                                           class="text-blue-400 hover:underline">
                                            View Logs
                                        </a>
                                    </td>

                                </tr>
                            <% }) %>

                        </tbody>

                    </table>

                </div>

            </div>

        <% }) %>

    </div>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Deployment Logs</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-950 text-white min-h-screen">

    <!-- Header -->
    <div class="border-b border-zinc-800 p-6">
        <h1 class="text-2xl font-bold">Deployment Logs</h1>
        <p class="text-zinc-400 text-sm">
            Deployment ID: <%= deployment._id %>
        </p>
    </div>

    <!-- Status Section -->
    <div class="p-6 flex gap-4 items-center">

        <span class="
            px-3 py-1 rounded text-xs font-semibold
            <%= deployment.status === 'success' ? 'bg-green-600' : '' %>
            <%= deployment.status === 'failed' ? 'bg-red-600' : '' %>
            <%= deployment.status === 'building' ? 'bg-yellow-600' : '' %>
            <%= deployment.status === 'queued' ? 'bg-zinc-600' : '' %>
        ">
            <%= deployment.status %>
        </span>

        <p class="text-zinc-400 text-sm">
            Container: <%= deployment.containerId || "N/A" %>
        </p>

        <p class="text-zinc-400 text-sm">
            URL: <%= deployment.deployedUrl || "Not deployed yet" %>
        </p>

    </div>

    <!-- Logs Box -->
    <div class="p-6">

        <div class="bg-black border border-zinc-800 rounded-xl p-4 h-[500px] overflow-y-auto font-mono text-sm">

            <% if (deployment.logs && deployment.logs.length > 0) { %>

                <% deployment.logs.forEach(log => { %>
                    <div class="text-green-400">
                        [<%= new Date(log.time).toLocaleTimeString() %>]
                        <%= log.message %>
                    </div>
                <% }) %>

            <% } else { %>

                <p class="text-zinc-500">
                    No logs available yet...
                </p>

            <% } %>

        </div>

    </div>

</body>
</html>
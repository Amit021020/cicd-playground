<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Login | CI/CD Playground</title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-950 text-white min-h-screen flex items-center justify-center">

    <div class="w-full max-w-md bg-zinc-900 border border-zinc-800 rounded-2xl p-8 shadow-2xl">

        <!-- Heading -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold">Welcome Back</h1>
            <p class="text-zinc-400 mt-2 text-sm">
                Login to access your deployments and projects.
            </p>
        </div>

        <!-- Form -->
        <form action="/login" method="post" class="space-y-5">

            <!-- Email -->
            <div>
                <label class="block mb-2 text-sm font-medium text-zinc-300">
                    Email
                </label>

                <input
                    type="email"
                    name="email"
                    placeholder="Enter your email"
                    class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 outline-none focus:border-blue-500 transition"
                    required
                />
            </div>

            <!-- Password -->
            <div>
                <label class="block mb-2 text-sm font-medium text-zinc-300">
                    Password
                </label>

                <input
                    type="password"
                    name="password"
                    placeholder="Enter your password"
                    class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 outline-none focus:border-blue-500 transition"
                    required
                />
            </div>

            <!-- Login Button -->
            <button
                type="submit"
                class="w-full bg-blue-600 hover:bg-blue-700 transition rounded-xl py-3 font-semibold"
            >
                Login
            </button>
        </form>

        <!-- Footer -->
        <p class="text-sm text-zinc-400 mt-6 text-center">
            Don’t have an account?
            <a href="/register" class="text-blue-500 hover:underline">
                Register
            </a>
        </p>

    </div>

</body>
</html>